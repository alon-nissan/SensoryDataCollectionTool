# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Publisher APIs (optional — needed for non-open-access papers)
ELSEVIER_API_KEY=your-elsevier-api-key-here
ELSEVIER_INSTTOKEN=your-institutional-token-here
SPRINGER_API_KEY=your-springer-api-key-here
WILEY_TDM_TOKEN=your-wiley-tdm-token-here

# Institutional login (for Shibboleth-protected publishers like OUP)
HUJI_EMAIL=your-huji-email@mail.huji.ac.il
HUJI_PASSWORD=your-huji-password-here
