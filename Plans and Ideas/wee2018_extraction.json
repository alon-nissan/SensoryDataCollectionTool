      "derived_metrics": {
        "dose_response_model": {
          "model_name": "Hill equation",
          "equation": "R = Rmin + (Rmax - Rmin) / (1 + 10^((logEC50 - C) * HillSlope))",
          "software": "Origin Pro 8.1 (OriginLab, Northampton, MA, USA)",
          "Rmin_constraint": "constrained to zero",
          "goodness_of_fit": "r2 >= 0.95 for all sweeteners",
          "parameters_note": "Full Hill equation parameters (Rmax, EC50, HillSlope) are in supplementary Table S2 (not available in main paper)"
        },

        "sweetness_growth_rate": {
          "model_name": "Stevens' power law",
          "equation": "log R = n * log C + log k",
          "description": "Slope (n) = rate of change in sweetness intensity per unit log-concentration. n>1 means intensity grows faster than concentration; n<1 means slower.",
          "source": "Table 3",
          "data": [
            {"stimulus_id": "ACE", "slope_n": 0.68, "intercept_log_k": 1.65},
