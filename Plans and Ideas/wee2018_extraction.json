{
  "study_metadata": {
    "study_id": "wee2018",
    "doi": "10.3390/nu10111632",
    "title": "A Comparison of Psychophysical Dose-Response Behaviour across 16 Sweeteners",
    "authors": ["May Wee", "Vicki Tan", "Ciarán Forde"],
    "year": 2018,
    "journal": "Nutrients",
    "country": "Singapore",
    "institution": "Clinical Nutrition Research Centre (CNRC), A*STAR; National University of Singapore",
    "food_category": "sweetener solutions",
    "keywords": ["sweeteners", "sugar reduction", "psychophysical dose-response", "sweetness growth rate", "sweetness potency"],
    "funding": "Biomedical Science Institute Strategic Positioning Fund Grant (G00067; BMSI/13-80048C-SICS)",
    "ethics_approval": "Domain Specific Review Board, National Healthcare Group, Singapore (ref: 2017/00787)"
  },

  "experiments": [
    {
      "experiment_id": "wee2018_exp1",
      "experiment_description": "Psychophysical dose-response evaluation of sweetness intensity across 16 sweeteners using gLMS",

      "panel": {
        "panel_type": "untrained",
        "panel_size": 40,
        "demographics": {
          "males": 12,
          "females": 28,
          "age_mean": 26,
          "age_sd": 6,
          "age_range": [21, 50]
        },
        "screening_criteria": [
          "healthy adults",
          "normal weight (BMI 20-25 kg/m2)",
          "non-smoker",
          "non-denture wearer",
          "no self-reported sinus, taste or smell dysfunction",
          "not following special diet",
          "no food dislikes, allergies or intolerances",
          "not phenylketonuric, diabetic or pregnant"
        ],
        "prescreening": "basic taste sensitivity screening"
      },

      "session_design": {
        "total_sessions": 5,
        "training_sessions": 1,
        "test_sessions": 4,
        "session_duration": "1 hour",
        "sweetener_sets_per_session": 4,
        "samples_per_set": 8,
        "design_type": "Williams Latin Square",
        "presentation_order": "randomized within each sweetener set and balanced across participants and sessions",
        "warmup_sample": "duplicate of sample 4/5 presented first (data excluded from analysis)",
        "sample_volume": "15 mL",
        "hold_time": "5 seconds in mouth before rating",
        "expectorate": true,
        "inter_stimulus_interval": "45 seconds mandatory",
        "palate_cleanser": "filtered water rinse",
        "environment": "sensory booths under red lights conforming to ISO standards for test rooms (ISO 8589)",
        "sample_preparation": "prepared at least 24h prior using filtered water, stored at refrigeration temperature",
        "data_collection_software": "Compusense Cloud (Compusense Inc., Guelph, ON, Canada)"
      },

      "scale": {
        "type": "gLMS",
        "full_name": "general Labelled Magnitude Scale",
        "range": [0, 100],
        "anchors": {
          "0": "no sensation",
          "1.5": "barely detectable",
          "6": "weak",
          "17": "moderate",
          "35": "strong",
          "52": "very strong",
          "100": "strongest imaginable sensation"
        },
        "standardization_method": "weight comparison modality matching task",
        "standardization_details": "Participants rated heaviness of weight stimuli on gLMS. Personal standardization factor = grand mean heaviness / individual average heaviness. Sweetness ratings multiplied by personal factor to correct for idiosyncratic scale use.",
        "standardization_validation": "Significant correlation between sweetness ratings and heaviness ratings (r=0.472, p<0.05)"
      },

      "training_protocol": {
        "description": "Familiarization with gLMS scale",
        "steps": [
          "Rate overall taste intensity for 7 imagined/recalled sensations (e.g., warmth of lukewarm water, pain from biting tongue)",
          "Rate 4 basic taste samples: sweet (sucrose), salty (NaCl), sour (citric acid), bitter (caffeine)"
        ]
      },

