  "experiments": [
    {
      "experiment_id": "benabu2018_exp1",
      "experiment_description": "Effect of sugar additions on taste profile of 0.05M KCl. Within-subjects design with sucrose and trehalose at multiple concentrations.",

      "panel": {
        "panel_type": "untrained",
        "panel_size": 30,
        "demographics": {
          "males": 16,
          "females": 14,
          "age_mean": 26.85,
          "age_sd": 4.3,
          "age_range": [22, 34.5]
        },
        "screening_criteria": [
          "no renal diseases",
          "no diabetes",
          "not pregnant",
          "no food intolerance or allergies",
          "no tobacco use",
          "no medication that would alter taste or smell"
        ],
        "recruitment": "online advertisements and flyers at Faculty of Agriculture, Food and Environment, Hebrew University"
      },

      "session_design": {
        "total_sessions": 2,
        "session_A": {
          "name": "baseline of sugars",
          "samples": ["water", "0.05M sucrose", "0.1M sucrose", "0.2M sucrose", "0.1M trehalose", "0.2M trehalose", "0.8M trehalose"],
          "purpose": "Establish baseline sweetness of pure sugars"
        },
        "session_B": {
          "name": "KCl + sugar mixtures",
          "samples": ["0.05M KCl", "0.05M KCl + 0.05M sucrose", "0.05M KCl + 0.1M sucrose", "0.05M KCl + 0.2M sucrose", "0.05M KCl + 0.1M trehalose", "0.05M KCl + 0.2M trehalose", "0.05M KCl + 0.8M trehalose"],
          "purpose": "Measure effect of sugar addition on KCl taste"
        },
        "break_between_sessions": "10 minutes",
        "blinding": "participants unaware of specific purpose of each session; sessions labeled A and B",
        "presentation_order": "randomized within each session",
        "sample_coding": "3-digit random numbers",
        "sample_volume_ml": 7,
        "cup_type": "30 mL polyethylene cups",
        "hold_time": "gargle ~5 seconds",
        "expectorate": true,
        "inter_stimulus_interval": "30 seconds",
        "palate_cleanser": "water rinse after each solution",
        "serving_temperature": "room temperature",
        "instruction_to_not_eat": "1 hour prior to tasting, nothing except water",
        "environment": "individual computer booths, minimum distance 2.4m apart",
        "data_collection_software": "Compusense Cloud",
        "compensation": "show-up fee of 10 shekels + time-based; total 30-50 shekels (8.62-14.36 USD)"
      },

      "scale": {
        "type": "9-point Likert",
        "range": [1, 9],
        "anchors": {
          "1": "no sensation",
          "9": "extremely strong sensation"
        },
        "note": "Chosen over LMS due to participants' inexperience; LMS was used in preliminary tests but led to high variability"
      },

      "stimuli": [
